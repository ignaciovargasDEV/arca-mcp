# PostgreSQL local/general. Cambialo antes de levantar.
POSTGRES_DB=arca_mcp
POSTGRES_USER=arca_mcp_user
POSTGRES_PASSWORD=change-me-long-random-password

# El MCP queda publicado solo en 127.0.0.1 del host por docker-compose.
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Afip SDK. Necesario incluso para homologacion si tu cuenta lo requiere.
AFIP_ACCESS_TOKEN=

# false = homologacion/test. true = facturas reales.
PRODUCTION=false
ALLOW_PRODUCTION=false

# Produccion ARCA. Usá tus propios puntos de venta habilitados.
AFIP_CUIT=
AFIP_PUNTO_VENTA=
AFIP_PUNTO_VENTA_EXPORTACION=
AFIP_CERT_PATH=/certs/arca.crt
AFIP_KEY_PATH=/certs/arca.key

# Homologacion default del SDK.
TEST_CUIT=20409378472
TEST_PUNTO_VENTA=1

# Datos del emisor para el PDF.
EMISOR_NOMBRE=
EMISOR_DOMICILIO=
EMISOR_INICIO_ACTIVIDADES=
FACTURA_DESCRIPCION=Servicios
LOGO_PATH=

# 1 Productos, 2 Servicios, 3 ambos.
CONCEPTO=2
UMBRAL_CF=10000000
MAX_FACTURA_ARS=

# Factura E / exportacion de servicios por WSFEX.
# Verificá estos codigos con parametros_factura_e antes de emitir real.
EXPORTACION_TIPO=2
EXPORTACION_MONEDA=DOL
EXPORTACION_PAIS_DESTINO=
EXPORTACION_CUIT_PAIS=
EXPORTACION_IDIOMA=1
EXPORTACION_UMED=7
EXPORTACION_FORMA_PAGO=Contado

# SMTP opcional.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ACCOUNTANT_EMAIL=
ACCOUNTANT_NAME=
ACCOUNTANT_EMAIL_SUBJECT=Comprobantes emitidos - {desde} a {hasta}
EMAIL_MAX_ATTACHMENT_MB=15
